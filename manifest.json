{
  "manifest_version": 3,
  "name": "PitcherList Rank Overlay",
  "version": "1.0.8",
  "description": "Overlays PitcherList SP & RP rankings on ESPN Fantasy Baseball free agents.",
  "permissions": [
    "storage",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://*.espn.com/*",
    "https://pitcherlist.com/*",
    "https://baseball.fantasysports.yahoo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://fantasy.espn.com/baseball/*",
        "https://baseball.fantasysports.yahoo.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PitcherList Ranks"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}